# Supabase — copy to .env.local and fill in your values
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-anon-or-publishable-key>

# Subdomain apps (optional overrides; defaults match meetpawan.com DNS)
VITE_BLOG_HOSTNAME=blog.meetpawan.com
VITE_FRONTEND_HOSTNAME=frontend.meetpawan.com
#
# Local dev without /etc/hosts — modern browsers resolve *.localhost to 127.0.0.1:
#   http://blog.localhost:5199
#   http://frontend.localhost:5199
# Optional: map real hostnames via hosts → same URLs with .meetpawan.com

# Do NOT put your Resend API key here with VITE_ — it would ship to the browser.
# Contact-form email uses a Supabase Edge Function; set RESEND_API_KEY and
# NOTIFY_TO_EMAIL with: npx supabase secrets set ...

# Instructions for adding another subdomain:
# -> Adding another subdomain later: add YourApp.jsx, a VITE_*_HOSTNAME line in .env.example, and one entry to HOST_APP_ENTRIES with a unique devLocalHost like labs.localhost.
# -> Vercel: when DNS is ready, add frontend.meetpawan.com under the same project (same as blog); no code change required beyond what’s already in the table.
# -> Programmatic host (e.g. links): use getConfiguredHostForAppId("blog") instead of a hardcoded BLOG_HOSTNAME constant so it stays aligned with env.