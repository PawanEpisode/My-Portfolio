# Supabase — copy to .env.local and fill in your values
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-anon-or-publishable-key>

# Do NOT put your Resend API key here with VITE_ — it would ship to the browser.
# Contact-form email uses a Supabase Edge Function; set RESEND_API_KEY and
# NOTIFY_TO_EMAIL with: npx supabase secrets set ...